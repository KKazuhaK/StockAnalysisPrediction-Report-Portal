# Secrets / runtime data — never commit
config.yaml
/data/
*.db
*.db-wal
*.db-shm

# Go build outputs
/report-portal
/psp
*.exe
/dist/
/out/
/bin/

# Misc
.DS_Store
.env

# Default `go build` output (named after the directory)
/StockAnalysisPrediction-Report-Portal

# Local test sandbox
/local-build/

# Frontend dependencies — never commit
web/node_modules/

# Frontend build output: built by CI then go:embed'd. Keep the .gitkeep
# placeholder so `go build` compiles the embed even before the SPA is built.
internal/web/dist/*
!internal/web/dist/.gitkeep

# Editor / tool directories
.idea/
.vscode/
.claude/
.codex/
.cursor/
